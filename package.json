{
  "name": "weather-app",
  "type": "module",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run dev:front\" \"npm run mock\"",
    "dev:front": "vite --host 0.0.0.0 --port 5173",
    "mock": "json-server --watch mock/db.json --routes mock/routes.json --port 3001 --host 0.0.0.0",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "type:check": "tsc --noEmit",
    "prepare": "husky",
    "preview": "vite preview"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.1",
    "@fontsource-variable/inter": "^5.2.8",
    "@tailwindcss/vite": "^4.2.4",
    "@tanstack/react-query": "^5.100.9",
    "@tanstack/react-router": "^1.169.2",
    "@tanstack/react-router-devtools": "^1.166.13",
    "axios": "^1.16.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "lucide-react": "^1.14.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-hook-form": "^7.75.0",
    "recharts": "^3.8.1",
    "shadcn": "^4.7.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.4",
    "tw-animate-css": "^1.4.0",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^8.2.0",
    "@eslint-react/eslint-plugin": "^3.0.0",
    "@eslint/js": "^10.0.1",
    "@tanstack/router-plugin": "^1.167.35",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "eslint": "^10.2.1",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-boundaries": "^6.0.2",
    "eslint-plugin-format": "^2.0.1",
    "globals": "^17.5.0",
    "husky": "^9.1.7",
    "json-server": "^0.17.4",
    "lint-staged": "^17.0.2",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.10",
    "vite-tsconfig-paths": "^6.1.1"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "bash -lc 'tsc --noEmit -p tsconfig.json'",
      "eslint src --ext ts,tsx --report-unused-disable-directives --fix"
    ]
  }
}
